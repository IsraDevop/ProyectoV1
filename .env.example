# Database
DATABASE_URL=jdbc:postgresql://localhost:5433/yala_db
DB_USER=postgres
DB_PASS=postgres
SERVER_PORT=8081

# JWT - use a strong random secret with at least 32 characters
JWT_SECRET=replace-with-a-strong-32-character-minimum-secret
CCI_ENCRYPTION_KEY=replace-with-a-different-strong-32-character-minimum-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# Stripe sandbox
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# Amazon S3 image storage
AWS_REGION=us-east-1
AWS_S3_BUCKET=yala-collectibles-dev
AWS_S3_PUBLIC_URL_BASE=https://yala-collectibles-dev.s3.us-east-1.amazonaws.com

# Local AWS credentials only. In EC2/ECS production use an IAM role instead.
AWS_ACCESS_KEY_ID=replace-with-local-access-key
AWS_SECRET_ACCESS_KEY=replace-with-local-secret-key
# AWS_SESSION_TOKEN=

# Email via Resend SMTP
RESEND_API_KEY=re_replace_with_your_api_key
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
