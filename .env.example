# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/yala_db
DB_USER=postgres
DB_PASS=postgres

# JWT — use a strong random secret (min 32 chars)
JWT_SECRET=your-very-strong-secret-key-here-32-chars

# Stripe (sandbox)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here

# Mail SMTP (for JavaMailSender — use Resend SMTP)
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
